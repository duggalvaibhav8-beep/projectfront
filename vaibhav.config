kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4

nodes:
- role: control-plane
  image: kindest/node:v1.29.2
- role: worker
  image: kindest/node:v1.29.2
- role: worker
  image: kindest/node:v1.29.2
- role: worker
  image: kindest/node:v1.29.2

  extraPortMappings:
    - containerPort: 8088
      hostPort: 8088
      protocol: TCP

    - containerPort: 444
      hostPort: 444
      protocol: TCP
